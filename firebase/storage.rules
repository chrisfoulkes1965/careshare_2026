rules_version = '2';

// Task attachments: path careGroups/{careGroupId}/task_attachments/{taskId}/{fileName}
// Access aligned with care group membership (same idea as firestore careGrouper checks).

service firebase.storage {
  match /b/{bucket}/o {
    function careGroupData(careGroupDocId) {
      return firestore.get(/databases/(default)/documents/careGroups/$(careGroupDocId));
    }
    // Match Firestore: members live on the "team" doc; the linked doc holds
    // team-level fields. Direct membership on the path id, or membership on the document
    // linked by [careGroupId], must grant access.
    function isMemberOfCareGroupFromStorage(careGroupDocId) {
      return request.auth != null
        && (
          firestore.exists(
            /databases/(default)/documents/careGroups/$(careGroupDocId)/members/$(request.auth.uid)
          )
          || (
            firestore.exists(/databases/(default)/documents/careGroups/$(careGroupDocId))
            && careGroupData(careGroupDocId).data.careGroupId is string
            && firestore.exists(
              /databases/(default)/documents/careGroups/$(careGroupData(careGroupDocId).data.careGroupId)/members/$(request.auth.uid)
            )
          )
        );
    }

    // Matches Firestore [careTeamId] + [isCareGroupAdministratorForGroup]: resolve the
    // `members/{uid}` document used for roles (shell vs linked data doc), then require
    // [care_group_administrator]. Storage paths may use either doc id; both must evaluate
    // the same team + admin check.
    function memberExistsStorage(careGroupDocId) {
      return firestore.exists(
        /databases/(default)/documents/careGroups/$(careGroupDocId)/members/$(request.auth.uid)
      );
    }

    function careTeamIdStorage(careGroupDocId) {
      return memberExistsStorage(careGroupDocId)
        ? careGroupDocId
        : (
            firestore.exists(/databases/(default)/documents/careGroups/$(careGroupDocId))
            && 'careGroupId' in careGroupData(careGroupDocId).data
            && careGroupData(careGroupDocId).data.careGroupId is string
            ? careGroupData(careGroupDocId).data.careGroupId
            : careGroupDocId
          );
    }

    function isCareGroupAdministratorFromStorage(careGroupDocId) {
      let team = careTeamIdStorage(careGroupDocId);
      return request.auth != null
        && firestore.exists(/databases/(default)/documents/careGroups/$(team)/members/$(request.auth.uid))
        && 'care_group_administrator' in firestore.get(/databases/(default)/documents/careGroups/$(team)/members/$(request.auth.uid)).data.get('roles', []);
    }

    match /careGroups/{careGroupId}/task_attachments/{taskId}/{fileName} {
      allow read: if isMemberOfCareGroupFromStorage(careGroupId);
      allow create, update: if isMemberOfCareGroupFromStorage(careGroupId)
        && request.resource.size < 10 * 1024 * 1024;
      allow delete: if isMemberOfCareGroupFromStorage(careGroupId);
    }

    match /careGroups/{careGroupId}/medication_photos/{medicationId}/{fileName} {
      allow read: if isMemberOfCareGroupFromStorage(careGroupId);
      allow create, update: if isMemberOfCareGroupFromStorage(careGroupId)
        && request.resource.size < 8 * 1024 * 1024;
      allow delete: if isMemberOfCareGroupFromStorage(careGroupId);
    }

    // Expense receipts: careGroups/{careGroupId}/expense_receipts/{expenseId}/{fileName}
    match /careGroups/{careGroupId}/expense_receipts/{expenseId}/{fileName} {
      allow read: if isMemberOfCareGroupFromStorage(careGroupId);
      allow create, update: if isMemberOfCareGroupFromStorage(careGroupId)
        && request.resource.size < 10 * 1024 * 1024;
      allow delete: if isMemberOfCareGroupFromStorage(careGroupId);
    }

    // Document library — bytes kept when items are in Trash; app never hard-deletes.
    match /careGroups/{careGroupId}/doc_library/{fileId}/{fileName} {
      allow read: if isMemberOfCareGroupFromStorage(careGroupId);
      allow create, update: if isMemberOfCareGroupFromStorage(careGroupId)
        && request.resource.size < 10 * 1024 * 1024;
      allow delete: if false;
    }

    // Shared photo gallery — careGroups/{careGroupId}/gallery/{photoId}/{fileName}
    match /careGroups/{careGroupId}/gallery/{photoId}/{fileName} {
      allow read: if isMemberOfCareGroupFromStorage(careGroupId);
      allow create, update: if isMemberOfCareGroupFromStorage(careGroupId)
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches("image/.*");
      allow delete: if isMemberOfCareGroupFromStorage(careGroupId);
    }

    // Care group avatar — careGroups/{careGroupId}/group_avatar/{fileName}
    match /careGroups/{careGroupId}/group_avatar/{fileName} {
      allow read: if isMemberOfCareGroupFromStorage(careGroupId);
      allow create, update: if isCareGroupAdministratorFromStorage(careGroupId)
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches("image/.*");
      allow delete: if isCareGroupAdministratorFromStorage(careGroupId);
    }

    // Profile photos: users/{uid}/profile_photo/{fileName}
    match /users/{userId}/profile_photo/{fileName} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches("image/.*");
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
