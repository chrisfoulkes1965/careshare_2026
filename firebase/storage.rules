rules_version = '2';

// Task attachments: path careGroups/{careGroupId}/task_attachments/{taskId}/{fileName}
// Access aligned with care group membership (same idea as firestore careGrouper checks).

service firebase.storage {
  match /b/{bucket}/o {
    function careGroupData(hid) {
      return firestore.get(/databases/(default)/documents/careGroups/$(hid));
    }
    // Match Firestore: members live on the "team" doc; the linked doc holds household
    // fields. Direct membership on the path id, or membership on the document linked by
    // [careGroupId], must grant access.
    function isMemberOfCareGroupFromStorage(careGroupDocId) {
      return request.auth != null
        && (
          firestore.exists(
            /databases/(default)/documents/careGroups/$(careGroupDocId)/members/$(request.auth.uid)
          )
          || (
            firestore.exists(/databases/(default)/documents/careGroups/$(careGroupDocId))
            && careGroupData(careGroupDocId).data.careGroupId is string
            && firestore.exists(
              /databases/(default)/documents/careGroups/$(careGroupData(careGroupDocId).data.careGroupId)/members/$(request.auth.uid)
            )
          )
        );
    }

    match /careGroups/{careGroupId}/task_attachments/{taskId}/{fileName} {
      allow read: if isMemberOfCareGroupFromStorage(careGroupId);
      allow create, update: if isMemberOfCareGroupFromStorage(careGroupId)
        && request.resource.size < 10 * 1024 * 1024;
      allow delete: if isMemberOfCareGroupFromStorage(careGroupId);
    }

    match /careGroups/{careGroupId}/medication_photos/{medicationId}/{fileName} {
      allow read: if isMemberOfCareGroupFromStorage(careGroupId);
      allow create, update: if isMemberOfCareGroupFromStorage(careGroupId)
        && request.resource.size < 8 * 1024 * 1024;
      allow delete: if isMemberOfCareGroupFromStorage(careGroupId);
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
