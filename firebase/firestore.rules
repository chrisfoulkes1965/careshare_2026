rules_version = '2';

// CareShare 2.0 — starter security rules
// See requirements/FIRESTORE_RULES_MATRIX.md for rationale and TBD items.
// Tighten field-level validation before production; several paths are intentionally conservative.

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core auth helpers -------------------------------------------------

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function memberDoc(careGroupId, uid) {
      return /databases/$(database)/documents/careGroups/$(careGroupId)/members/$(uid);
    }

    function memberExists(careGroupId, uid) {
      return signedIn() && exists(memberDoc(careGroupId, uid));
    }

    function memberData(careGroupId, uid) {
      return get(memberDoc(careGroupId, uid)).data;
    }

    function hasRole(careGroupId, uid, role) {
      return memberExists(careGroupId, uid) && role in memberData(careGroupId, uid).roles;
    }

    function hasAnyRole(careGroupId, uid, roles) {
      return memberExists(careGroupId, uid)
        && memberData(careGroupId, uid).roles.hasAny(roles);
    }

    // True if the user is a member of this care group document OR of its linked
    // "team" document (legacy: two [careGroups] docs cross-linked by [careGroupId]).
    // New setup uses a single merged [careGroups] document with [members/] only.
    function isCareGroupMember(careGroupDocId) {
      return signedIn() && (
        memberExists(careGroupDocId, request.auth.uid)
        || (
          exists(/databases/$(database)/documents/careGroups/$(careGroupDocId))
          && get(/databases/$(database)/documents/careGroups/$(careGroupDocId)).data.keys().hasAny(['careGroupId'])
          && memberExists(
            get(/databases/$(database)/documents/careGroups/$(careGroupDocId)).data.careGroupId,
            request.auth.uid
          )
        )
      );
    }

    // The document id where members/{uid} and roles are stored.
    function careTeamId(careGroupDocId) {
      return memberExists(careGroupDocId, request.auth.uid)
        ? careGroupDocId
        : (
            exists(/databases/$(database)/documents/careGroups/$(careGroupDocId))
            && get(/databases/$(database)/documents/careGroups/$(careGroupDocId)).data.keys().hasAny(['careGroupId'])
            ? get(/databases/$(database)/documents/careGroups/$(careGroupDocId)).data.careGroupId
            : careGroupDocId
          );
    }

    function isPrincipalCarerOrCareGroupAdminForCareGroup(careGroupId) {
      let team = careTeamId(careGroupId);
      return hasAnyRole(team, request.auth.uid, ['principal_carer', 'care_group_administrator']);
    }

    function isCareGroupAdministratorForGroup(careGroupDocId) {
      let team = careTeamId(careGroupDocId);
      return signedIn() && hasRole(team, request.auth.uid, 'care_group_administrator');
    }

    /// Updates that only touch shared home labels / linked calendar config (not recipients, pathways, etc.).
    function careGroupNameThemeOrCalendarPatchOnly() {
      return diffKeys().hasOnly(['name'])
        || diffKeys().hasOnly(['themeColor'])
        || diffKeys().hasOnly(['groupCalendar'])
        || diffKeys().hasOnly(['name', 'themeColor'])
        || diffKeys().hasOnly(['name', 'groupCalendar'])
        || diffKeys().hasOnly(['themeColor', 'groupCalendar'])
        || diffKeys().hasOnly(['name', 'themeColor', 'groupCalendar']);
    }

    function careGroupLegacyLinkFieldStable() {
      return (!resource.data.keys().hasAny(['careGroupId']) && !request.resource.data.keys().hasAny(['careGroupId']))
        || (
          resource.data.keys().hasAny(['careGroupId'])
          && request.resource.data.keys().hasAny(['careGroupId'])
          && request.resource.data.careGroupId == resource.data.careGroupId
        );
    }

    function isCarerOrPrincipalForCareGroup(careGroupId) {
      let team = careTeamId(careGroupId);
      return hasAnyRole(team, request.auth.uid, ['principal_carer', 'carer', 'care_group_administrator']);
    }

    function isFinancialOrPrincipalForCareGroup(careGroupId) {
      let team = careTeamId(careGroupId);
      return hasAnyRole(team, request.auth.uid, ['principal_carer', 'financial_manager', 'care_group_administrator']);
    }

    function isExpenseReaderForCareGroup(careGroupId) {
      let team = careTeamId(careGroupId);
      // Conservative default from matrix: plain carers excluded until product confirms.
      return hasAnyRole(team, request.auth.uid, [
        'principal_carer',
        'financial_manager',
        'power_of_attorney',
        'care_group_administrator',
      ]);
    }

    function isPrincipalOrPoaForCareGroup(careGroupId) {
      let team = careTeamId(careGroupId);
      return hasAnyRole(team, request.auth.uid, ['principal_carer', 'power_of_attorney', 'care_group_administrator']);
    }

    function isReceivesCareOnlyMember(careGroupId) {
      let team = careTeamId(careGroupId);
      return memberExists(team, request.auth.uid)
        && hasRole(team, request.auth.uid, 'receives_care')
        && !hasAnyRole(team, request.auth.uid, [
          'principal_carer',
          'carer',
          'financial_manager',
          'power_of_attorney',
          'care_group_administrator',
        ]);
    }

    function canReadTaskAsRecipientUser(task) {
      // TODO: align recipientId semantics (profile id vs auth uid) on tasks.
      return (task.keys().hasAny(['assignedTo']) && task.assignedTo == request.auth.uid)
        || (task.keys().hasAny(['recipientId']) && task.recipientId == request.auth.uid);
    }

    function noteRequiresPrincipalOrPoa(note) {
      return (note.keys().hasAny(['sensitive']) && note.sensitive == true)
        || (note.keys().hasAny(['category']) && note.category == 'legal');
    }

    function canReadMedicationList(careGroupId) {
      let team = careTeamId(careGroupId);
      return isCarerOrPrincipalForCareGroup(careGroupId)
        || hasRole(team, request.auth.uid, 'power_of_attorney');
    }

    /// Plain [carer] role only (not principal, POA, or care group admin) — inventory / dose logging.
    function isCarerOnlyMember(careGroupId) {
      let team = careTeamId(careGroupId);
      return memberExists(team, request.auth.uid)
        && hasRole(team, request.auth.uid, 'carer')
        && !hasAnyRole(team, request.auth.uid, [
          'principal_carer',
          'power_of_attorney',
          'care_group_administrator',
        ]);
    }

    function medicationPrincipalPatchKeys() {
      return [
        'name', 'dosage', 'instructions', 'notes', 'photoUrl',
        'reminderEnabled', 'reminderTimes', 'reminderSchedule', 'reminderWeekdays', 'reminderMonthDays',
        'quantityOnHand', 'lowStockThreshold',
      ];
    }

    function medicationCreatedStable() {
      return request.resource.data.createdBy == resource.data.createdBy;
    }

    function medicationPrincipalUpdateOk(careGroupId) {
      return isPrincipalOrPoaForCareGroup(careGroupId)
        && diffKeys().hasOnly(medicationPrincipalPatchKeys())
        && medicationCreatedStable()
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 200
        && (!request.resource.data.keys().hasAny(['dosage']) || (
          request.resource.data.dosage is string && request.resource.data.dosage.size() <= 4000
        ))
        && (!request.resource.data.keys().hasAny(['instructions']) || (
          request.resource.data.instructions is string && request.resource.data.instructions.size() <= 4000
        ))
        && (!request.resource.data.keys().hasAny(['notes']) || (
          request.resource.data.notes is string && request.resource.data.notes.size() <= 4000
        ))
        && (!request.resource.data.keys().hasAny(['photoUrl']) || (
          request.resource.data.photoUrl is string && request.resource.data.photoUrl.size() <= 2048
        ))
        && (!request.resource.data.keys().hasAny(['reminderEnabled']) || request.resource.data.reminderEnabled is bool)
        && (!request.resource.data.keys().hasAny(['reminderTimes']) || request.resource.data.reminderTimes is list)
        && (!request.resource.data.keys().hasAny(['reminderSchedule']) || (
          request.resource.data.reminderSchedule is string
          && request.resource.data.reminderSchedule in ['daily', 'weekly', 'monthly']
        ))
        && (!request.resource.data.keys().hasAny(['reminderWeekdays']) || request.resource.data.reminderWeekdays is list)
        && (!request.resource.data.keys().hasAny(['reminderMonthDays']) || request.resource.data.reminderMonthDays is list)
        && (!request.resource.data.keys().hasAny(['quantityOnHand']) || (
          request.resource.data.quantityOnHand is int
          && request.resource.data.quantityOnHand >= 0
          && request.resource.data.quantityOnHand < 2000000000
        ))
        && (!request.resource.data.keys().hasAny(['lowStockThreshold']) || (
          request.resource.data.lowStockThreshold is int
          && request.resource.data.lowStockThreshold >= 0
          && request.resource.data.lowStockThreshold < 2000000000
        ));
    }

    function medicationCarerQuantityPatchOk(careGroupId) {
      return isCarerOnlyMember(careGroupId)
        && diffKeys().hasOnly(['quantityOnHand'])
        && medicationCreatedStable()
        && (
          !request.resource.data.keys().hasAny(['quantityOnHand'])
          || (
            request.resource.data.quantityOnHand is int
            && request.resource.data.quantityOnHand >= 0
            && request.resource.data.quantityOnHand < 2000000000
          )
        );
    }

    function medicationCreateKeysOk() {
      return request.resource.data.keys().hasOnly([
        'name', 'dosage', 'instructions', 'notes', 'photoUrl',
        'reminderEnabled', 'reminderTimes', 'reminderSchedule', 'reminderWeekdays', 'reminderMonthDays',
        'quantityOnHand', 'lowStockThreshold', 'createdBy', 'createdAt',
      ]);
    }

    function canAuthorCareGroupNotes(careGroupId) {
      let team = careTeamId(careGroupId);
      return hasAnyRole(team, request.auth.uid, [
        'principal_carer',
        'carer',
        'power_of_attorney',
        'care_group_administrator',
      ]);
    }

    function diffKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function diffKeysCreate() {
      return request.resource.data.keys();
    }

    function emailMatchesInvite(invitation) {
      return invitation.keys().hasAny(['invitedEmail'])
        && request.auth.token.keys().hasAny(['email'])
        && invitation.invitedEmail == request.auth.token.email;
    }

    function invitationRolesValid(roles) {
      return roles is list
        && roles.size() >= 1
        && roles.size() <= 6
        && roles.hasOnly([
          'principal_carer',
          'care_group_administrator',
          'carer',
          'financial_manager',
          'power_of_attorney',
          'receives_care',
        ]);
    }

    // --- Top-level collections ---------------------------------------------

    match /users/{userId} {
      allow read: if isSelf(userId);

      allow create: if isSelf(userId)
        && diffKeysCreate().hasOnly([
          'displayName',
          'email',
          'photoUrl',
          'avatarIndex',
          'phone',
          'dateOfBirth',
          'simpleMode',
          'createdAt',
        ]);

      allow update: if isSelf(userId)
        && !diffKeys().hasAny(['careGroupIds']);

      allow delete: if false;
    }

    match /users/{userId}/notifications/{notificationId} {
      allow read, update: if isSelf(userId);
      allow create, delete: if false;
    }

    match /users/{userId}/devicePushTokens/{docId} {
      allow read, create, update, delete: if isSelf(userId);
    }

    match /invitations/{invitationId} {
      // Single-document load for invitation links before sign-in (pending only, no auth).
      allow get: if (
        !signedIn()
        && resource.data.keys().hasAll(['careGroupId', 'status', 'invitedEmail'])
        && resource.data.status == 'pending'
      ) || (
        signedIn()
        && (
          emailMatchesInvite(resource.data)
          || (
            resource.data.keys().hasAll(['careGroupId'])
            && isCareGroupMember(resource.data.careGroupId)
          )
        )
      );

      allow list: if signedIn()
        && resource.data.keys().hasAll(['careGroupId'])
        && isCareGroupMember(resource.data.careGroupId);

      allow create: if signedIn()
        && request.resource.data.keys().hasAll([
          'careGroupId',
          'dataCareGroupId',
          'invitedEmail',
          'invitedBy',
          'invitedRoles',
          'status',
          'createdAt',
        ])
        && invitationRolesValid(request.resource.data.invitedRoles)
        && hasAnyRole(careTeamId(request.resource.data.careGroupId), request.auth.uid, ['principal_carer', 'care_group_administrator'])
        && request.resource.data.invitedBy == request.auth.uid
        && request.resource.data.status == 'pending';

      // Invitee (matching email) may patch any fields once the invite is pending,
      // including funnel timestamps and `status` flipping to accepted/declined.
      // Group admins/principals retain full control of invitations they own.
      allow update: if signedIn() && (
        (
          emailMatchesInvite(resource.data)
          && resource.data.status == 'pending'
        )
        || (
          resource.data.keys().hasAny(['careGroupId'])
          && hasAnyRole(careTeamId(resource.data.careGroupId), request.auth.uid, ['principal_carer', 'care_group_administrator'])
        )
      );

      allow delete: if signedIn()
        && resource.data.keys().hasAny(['careGroupId'])
        && hasAnyRole(careTeamId(resource.data.careGroupId), request.auth.uid, ['principal_carer', 'care_group_administrator']);
    }

    match /carePathways/{pathwayId} {
      allow read: if signedIn() && (
        resource.data.system == true
        || (
          resource.data.system == false
          && resource.data.keys().hasAny(['createdBy'])
          && resource.data.createdBy == request.auth.uid
        )
      );

      allow create: if signedIn()
        && request.resource.data.system == false
        && request.resource.data.createdBy == request.auth.uid;

      allow update, delete: if signedIn()
        && resource.data.system == false
        && resource.data.keys().hasAny(['createdBy'])
        && resource.data.createdBy == request.auth.uid;
    }

    match /careGroups/{careGroupId}/members/{userId} {
      // Read own member doc even when not yet a member (needed by the
      // [redeemInvitationForSignedInUser] transaction which reads `members/{uid}`
      // before creating it to merge roles when an invite is re-sent).
      allow get: if isSelf(userId) || isCareGroupMember(careGroupId);
      allow list: if isCareGroupMember(careGroupId);

      allow create: if signedIn() && (
        (
          isSelf(userId)
          && request.resource.data.keys().hasAll(['roles', 'displayName', 'joinedAt', 'kudosScore'])
        )
        || hasAnyRole(careTeamId(careGroupId), request.auth.uid, ['principal_carer', 'care_group_administrator'])
      );

      allow update: if signedIn()
        && isCareGroupMember(careGroupId)
        && !diffKeys().hasAny(['kudosScore'])
        && (
          (
            isSelf(userId)
            && diffKeys().hasOnly(['messagingToken', 'simpleMode', 'displayName', 'photoUrl', 'avatarIndex'])
          )
          || (
            hasAnyRole(careTeamId(careGroupId), request.auth.uid, ['principal_carer', 'care_group_administrator'])
            && !diffKeys().hasAny(['joinedAt'])
          )
        );

      allow delete: if signedIn()
        && hasAnyRole(careTeamId(careGroupId), request.auth.uid, ['principal_carer', 'care_group_administrator'])
        && !isSelf(userId);
    }

    // Recommended chat location (not in brief schema; adjust if you nest under careGroups).
    match /careGroups/{careGroupId}/messages/{messageId} {
      allow read: if signedIn()
        && isCareGroupMember(careGroupId)
        && !isReceivesCareOnlyMember(careGroupId);

      allow create: if signedIn()
        && isCareGroupMember(careGroupId)
        && !isReceivesCareOnlyMember(careGroupId)
        && request.resource.data.keys().hasAll(['senderId', 'createdAt', 'body'])
        && request.resource.data.senderId == request.auth.uid;

      allow update, delete: if false;
    }

    match /careGroups/{careGroupId} {
      allow read: if isCareGroupMember(careGroupId);

      allow create: if signedIn() && (
        (
          request.resource.data.keys().hasAll(['careGroupId', 'name', 'createdBy', 'createdAt'])
          && request.resource.data.createdBy == request.auth.uid
        )
        || (
          request.resource.data.keys().hasAll(['name', 'careGroupId', 'recipientIds', 'pathwayIds', 'address', 'addressType', 'createdBy', 'createdAt'])
          && request.resource.data.createdBy == request.auth.uid
          && isCareGroupMember(request.resource.data.careGroupId)
        )
        || (
          request.resource.data.keys().hasAll(['name', 'description', 'recipientIds', 'pathwayIds', 'recipientProfiles', 'address', 'addressType', 'createdBy', 'createdAt'])
          && request.resource.data.createdBy == request.auth.uid
          && !request.resource.data.keys().hasAny(['careGroupId'])
        )
      );

      // Name, theme, and linked calendar config: **care_group_administrator only** (principal carer excluded).
      // Other careGroups fields: principal carer or care group administrator without touching appearance/calendar keys.
      allow update: if signedIn()
        && (
          (
            isCareGroupAdministratorForGroup(careGroupId)
            && careGroupNameThemeOrCalendarPatchOnly()
            && careGroupLegacyLinkFieldStable()
          )
          || (
            isPrincipalCarerOrCareGroupAdminForCareGroup(careGroupId)
            && !diffKeys().hasAny(['name', 'themeColor', 'groupCalendar'])
            && careGroupLegacyLinkFieldStable()
          )
        );

      allow delete: if false;

      match /tasks/{taskId} {
        allow read: if isCareGroupMember(careGroupId)
          && (
            !isReceivesCareOnlyMember(careGroupId)
            || canReadTaskAsRecipientUser(resource.data)
          );

        allow create: if isCareGroupMember(careGroupId)
          && isCarerOrPrincipalForCareGroup(careGroupId)
          && request.resource.data.keys().hasAll(['title', 'status', 'createdBy', 'createdAt'])
          && request.resource.data.createdBy == request.auth.uid;

        allow update: if isCareGroupMember(careGroupId)
          && isCarerOrPrincipalForCareGroup(careGroupId)
          && request.resource.data.createdBy == resource.data.createdBy;

        allow delete: if isPrincipalCarerOrCareGroupAdminForCareGroup(careGroupId);
      }

      match /notes/{noteId} {
        allow read: if isCareGroupMember(careGroupId)
          && (
            !noteRequiresPrincipalOrPoa(resource.data)
            || isPrincipalOrPoaForCareGroup(careGroupId)
          )
          && (
            !isReceivesCareOnlyMember(careGroupId)
            || !noteRequiresPrincipalOrPoa(resource.data)
          );

        allow create: if isCareGroupMember(careGroupId)
          && canAuthorCareGroupNotes(careGroupId)
          && request.resource.data.keys().hasAll(['title', 'type', 'createdBy', 'createdAt'])
          && request.resource.data.createdBy == request.auth.uid;

        allow update: if isCareGroupMember(careGroupId)
          && canAuthorCareGroupNotes(careGroupId);

        allow delete: if isPrincipalOrPoaForCareGroup(careGroupId);
      }

      match /journalEntries/{entryId} {
        allow read: if isCareGroupMember(careGroupId)
          && !isReceivesCareOnlyMember(careGroupId);

        allow create: if isCareGroupMember(careGroupId)
          && isCarerOrPrincipalForCareGroup(careGroupId);

        allow update: if isCareGroupMember(careGroupId)
          && isCarerOrPrincipalForCareGroup(careGroupId);

        allow delete: if isPrincipalCarerOrCareGroupAdminForCareGroup(careGroupId);
      }

      match /medications/{medicationId} {
        allow read: if isCareGroupMember(careGroupId) && canReadMedicationList(careGroupId);

        allow create: if isPrincipalOrPoaForCareGroup(careGroupId)
          && medicationCreateKeysOk()
          && request.resource.data.keys().hasAll(['name', 'createdBy', 'createdAt'])
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.name is string
          && request.resource.data.name.size() >= 1
          && request.resource.data.name.size() <= 200
          && (!request.resource.data.keys().hasAny(['dosage']) || (
            request.resource.data.dosage is string && request.resource.data.dosage.size() <= 4000
          ))
          && (!request.resource.data.keys().hasAny(['instructions']) || (
            request.resource.data.instructions is string && request.resource.data.instructions.size() <= 4000
          ))
          && (!request.resource.data.keys().hasAny(['notes']) || (
            request.resource.data.notes is string && request.resource.data.notes.size() <= 4000
          ))
          && (!request.resource.data.keys().hasAny(['photoUrl']) || (
            request.resource.data.photoUrl is string && request.resource.data.photoUrl.size() <= 2048
          ))
          && (!request.resource.data.keys().hasAny(['reminderEnabled']) || request.resource.data.reminderEnabled is bool)
          && (!request.resource.data.keys().hasAny(['reminderTimes']) || request.resource.data.reminderTimes is list)
          && (!request.resource.data.keys().hasAny(['reminderSchedule']) || (
            request.resource.data.reminderSchedule is string
            && request.resource.data.reminderSchedule in ['daily', 'weekly', 'monthly']
          ))
          && (!request.resource.data.keys().hasAny(['reminderWeekdays']) || request.resource.data.reminderWeekdays is list)
          && (!request.resource.data.keys().hasAny(['reminderMonthDays']) || request.resource.data.reminderMonthDays is list)
          && (!request.resource.data.keys().hasAny(['quantityOnHand']) || (
            request.resource.data.quantityOnHand is int
            && request.resource.data.quantityOnHand >= 0
            && request.resource.data.quantityOnHand < 2000000000
          ))
          && (!request.resource.data.keys().hasAny(['lowStockThreshold']) || (
            request.resource.data.lowStockThreshold is int
            && request.resource.data.lowStockThreshold >= 0
            && request.resource.data.lowStockThreshold < 2000000000
          ));

        allow update: if isCareGroupMember(careGroupId) && (
          medicationPrincipalUpdateOk(careGroupId)
          || medicationCarerQuantityPatchOk(careGroupId)
        );

        allow delete: if isPrincipalOrPoaForCareGroup(careGroupId);

        match /doseLogs/{logId} {
          allow read: if isCareGroupMember(careGroupId) && canReadMedicationList(careGroupId);

          allow create: if isCareGroupMember(careGroupId)
            && isCarerOrPrincipalForCareGroup(careGroupId)
            && request.resource.data.keys().hasAll(['takenAt', 'loggedBy'])
            && request.resource.data.loggedBy == request.auth.uid
            && request.resource.data.takenAt is timestamp
            && request.resource.data.keys().hasOnly(['takenAt', 'loggedBy', 'slotKey'])
            && (!request.resource.data.keys().hasAny(['slotKey'])
              || (request.resource.data.slotKey is string && request.resource.data.slotKey.size() <= 200));

          allow update, delete: if false;
        }
      }

      match /medicationBatchPrep/{prepId} {
        allow read: if isCareGroupMember(careGroupId) && canReadMedicationList(careGroupId);

        allow create: if isCareGroupMember(careGroupId)
          && isCarerOrPrincipalForCareGroup(careGroupId)
          && request.resource.data.keys().hasAll(['weekKey', 'completedMedicationIds', 'updatedBy'])
          && request.resource.data.updatedBy == request.auth.uid
          && request.resource.data.weekKey is string
          && request.resource.data.weekKey.size() <= 16
          && request.resource.data.completedMedicationIds is list
          && request.resource.data.keys().hasOnly(['weekKey', 'completedMedicationIds', 'updatedBy', 'updatedAt']);

        allow update: if isCareGroupMember(careGroupId)
          && isCarerOrPrincipalForCareGroup(careGroupId)
          && request.resource.data.updatedBy == request.auth.uid
          && diffKeys().hasOnly(['weekKey', 'completedMedicationIds', 'updatedBy', 'updatedAt'])
          && (!request.resource.data.keys().hasAny(['weekKey'])
            || (request.resource.data.weekKey is string && request.resource.data.weekKey.size() <= 16))
          && (!request.resource.data.keys().hasAny(['completedMedicationIds'])
            || request.resource.data.completedMedicationIds is list);

        allow delete: if isPrincipalOrPoaForCareGroup(careGroupId);
      }

      match /expenses/{expenseId} {
        function expenseOptionalStringsOk() {
          return (!request.resource.data.keys().hasAny(['category'])
              || (request.resource.data.category is string
                && request.resource.data.category.size() <= 50))
            && (!request.resource.data.keys().hasAny(['payee'])
              || (request.resource.data.payee is string
                && request.resource.data.payee.size() <= 200))
            && (!request.resource.data.keys().hasAny(['notes'])
              || (request.resource.data.notes is string
                && request.resource.data.notes.size() <= 4000))
            && (!request.resource.data.keys().hasAny(['receiptUrl'])
              || (request.resource.data.receiptUrl is string
                && request.resource.data.receiptUrl.size() > 0
                && request.resource.data.receiptUrl.size() <= 2048));
        }

        allow read: if isCareGroupMember(careGroupId) && isExpenseReaderForCareGroup(careGroupId);

        allow create: if isCareGroupMember(careGroupId)
          && isFinancialOrPrincipalForCareGroup(careGroupId)
          && request.resource.data.keys().hasAll([
            'title', 'amount', 'currency', 'spentAt', 'createdBy', 'createdAt',
          ])
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.title is string
          && request.resource.data.title.size() >= 1
          && request.resource.data.title.size() <= 200
          && request.resource.data.amount is number
          && request.resource.data.amount > 0
          && request.resource.data.amount < 1000000000000
          && request.resource.data.currency is string
          && request.resource.data.currency.size() >= 1
          && request.resource.data.currency.size() <= 8
          && request.resource.data.spentAt is timestamp
          && expenseOptionalStringsOk();

        allow update: if isCareGroupMember(careGroupId)
          && isFinancialOrPrincipalForCareGroup(careGroupId)
          && request.resource.data.createdBy == resource.data.createdBy
          && diffKeys().hasOnly([
            'title', 'amount', 'currency', 'spentAt', 'category', 'payee', 'notes', 'receiptUrl', 'updatedAt',
          ])
          && request.resource.data.title is string
          && request.resource.data.title.size() >= 1
          && request.resource.data.title.size() <= 200
          && request.resource.data.amount is number
          && request.resource.data.amount > 0
          && request.resource.data.amount < 1000000000000
          && request.resource.data.currency is string
          && request.resource.data.currency.size() >= 1
          && request.resource.data.currency.size() <= 8
          && request.resource.data.spentAt is timestamp
          && expenseOptionalStringsOk();

        allow delete: if isCareGroupMember(careGroupId)
          && isFinancialOrPrincipalForCareGroup(careGroupId);
      }

      match /linkedCalendarEvents/{linkedEventId} {
        allow read: if isCareGroupMember(careGroupId)
          && !isReceivesCareOnlyMember(careGroupId);

        allow create, update, delete: if false;
      }

      match /meetings/{meetingId} {
        allow read: if isCareGroupMember(careGroupId) && !isReceivesCareOnlyMember(careGroupId);

        allow create, update: if isCareGroupMember(careGroupId)
          && isCarerOrPrincipalForCareGroup(careGroupId);

        allow delete: if isPrincipalCarerOrCareGroupAdminForCareGroup(careGroupId);
      }

      match /documents/{documentId} {
        allow read: if isCareGroupMember(careGroupId) && (
          !resource.data.keys().hasAny(['category'])
          || resource.data.category in ['medical', 'other']
          || (
            resource.data.category == 'legal'
            && isPrincipalOrPoaForCareGroup(careGroupId)
          )
          || (
            resource.data.category == 'financial'
            && (
              isPrincipalOrPoaForCareGroup(careGroupId)
              || hasRole(careTeamId(careGroupId), request.auth.uid, 'financial_manager')
            )
          )
        );

        allow create: if isCareGroupMember(careGroupId)
          && (
            isPrincipalOrPoaForCareGroup(careGroupId)
            || (
              isCarerOrPrincipalForCareGroup(careGroupId)
              && request.resource.data.keys().hasAny(['category'])
              && request.resource.data.category in ['medical', 'other']
            )
          );

        allow update, delete: if isCareGroupMember(careGroupId)
          && isPrincipalOrPoaForCareGroup(careGroupId);
      }

      match /contacts/{contactId} {
        allow read: if isCareGroupMember(careGroupId);

        allow create, update, delete: if isCareGroupMember(careGroupId)
          && isCarerOrPrincipalForCareGroup(careGroupId);
      }

      match /checkins/{checkinId} {
        allow read: if isCareGroupMember(careGroupId)
          && (
            (
              resource.data.keys().hasAny(['private'])
              && resource.data.private == true
              && resource.data.keys().hasAny(['subjectId'])
              && resource.data.subjectId == request.auth.uid
            )
            || (
              (!resource.data.keys().hasAny(['private']) || resource.data.private == false)
              && !isReceivesCareOnlyMember(careGroupId)
            )
            || (
              (!resource.data.keys().hasAny(['private']) || resource.data.private == false)
              && isReceivesCareOnlyMember(careGroupId)
              && resource.data.keys().hasAny(['type'])
              && resource.data.type == 'recipient'
            )
          );

        allow create: if isCareGroupMember(careGroupId)
          && request.resource.data.keys().hasAll(['type', 'subjectId', 'score', 'createdAt'])
          && request.resource.data.subjectId == request.auth.uid;

        allow update, delete: if false;
      }

      // --- Care group chat (channels, messages, per-user read cursors) ----------------
      function isChatChannelMember(careGroupId, channelId) {
        let p = /databases/$(database)/documents/careGroups/$(careGroupId)/chatChannels/$(channelId);
        return exists(p)
          && get(p).data.keys().hasAny(['memberUids'])
          && request.auth.uid in get(p).data.memberUids;
      }

      match /userChannelRead/{userId} {
        match /channels/{channelId} {
          allow read, create, update: if signedIn()
            && isSelf(userId)
            && isCareGroupMember(careGroupId)
            && isChatChannelMember(careGroupId, channelId)
            && request.resource.data.keys().hasAll(['lastReadAt']);

          // Allow delete when leaving the channel (may happen before memberUids is updated).
          allow delete: if signedIn()
            && isSelf(userId)
            && isCareGroupMember(careGroupId);
        }
      }

      match /chatChannels/{channelId} {
        function validChatChannelWhatsappInviteUrl() {
          let w = request.resource.data.whatsappInviteUrl;
          return w is string
            && w.size() < 400
            && (w == ''
              || w.matches('^https://chat\\.whatsapp\\.com/.*'));
        }

        allow read: if isCareGroupMember(careGroupId)
          && request.auth.uid in resource.data.memberUids;

        allow create: if isCareGroupMember(careGroupId)
          && isCarerOrPrincipalForCareGroup(careGroupId)
          && !isReceivesCareOnlyMember(careGroupId)
          && request.resource.data.keys().hasAll(['name', 'createdBy', 'createdAt', 'memberUids'])
          && request.resource.data.createdBy == request.auth.uid
          && request.auth.uid in request.resource.data.memberUids
          && request.resource.data.memberUids is list
          && request.resource.data.memberUids.size() > 0
          && request.resource.data.memberUids.size() < 100;

        allow update: if isCareGroupMember(careGroupId)
          && request.auth.uid in resource.data.memberUids
          && (
            (
              isCarerOrPrincipalForCareGroup(careGroupId)
              && !isReceivesCareOnlyMember(careGroupId)
              && diffKeys().hasOnly(['name', 'description', 'topic', 'memberUids', 'whatsappInviteUrl'])
              && (!request.resource.data.keys().hasAny(['whatsappInviteUrl'])
                || validChatChannelWhatsappInviteUrl())
            )
            || (
              !request.auth.uid in request.resource.data.memberUids
              && request.resource.data.memberUids.size() + 1 == resource.data.memberUids.size()
              && diffKeys().hasOnly(['memberUids'])
            )
          );

        allow delete: if isPrincipalCarerOrCareGroupAdminForCareGroup(careGroupId);

        match /messages/{messageId} {
          allow read: if isCareGroupMember(careGroupId)
            && isChatChannelMember(careGroupId, channelId);

          allow create: if isCareGroupMember(careGroupId)
            && isChatChannelMember(careGroupId, channelId)
            && request.resource.data.keys().hasAll(['text', 'createdBy', 'createdAt'])
            && request.resource.data.createdBy == request.auth.uid
            && request.resource.data.text is string
            && request.resource.data.text.size() > 0
            && request.resource.data.text.size() < 8000;

          allow update, delete: if false;
        }
      }

      // Append-only audit trail (POA-sensitive actions). Prefer Cloud Function creates.
      match /auditLogs/{logId} {
        allow read: if isCareGroupMember(careGroupId) && isPrincipalOrPoaForCareGroup(careGroupId);
        allow create: if signedIn()
          && request.resource.data.keys().hasAll(['actorId', 'action', 'createdAt'])
          && request.resource.data.actorId == request.auth.uid;
        allow update, delete: if false;
      }

      // Tracking / telemetry — client writes off; principal/POA may read. Prefer Fn ingestion.
      match /tracking/{path=**} {
        allow read: if isCareGroupMember(careGroupId) && isPrincipalOrPoaForCareGroup(careGroupId);
        allow write: if false;
      }
    }

    match /config/{documentId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
