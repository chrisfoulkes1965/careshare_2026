rules_version = '2';

// CareShare 2.0 — starter security rules
// See requirements/FIRESTORE_RULES_MATRIX.md for rationale and TBD items.
// Tighten field-level validation before production; several paths are intentionally conservative.

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core auth helpers -------------------------------------------------

    function signedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function memberDoc(careGroupId, uid) {
      return /databases/$(database)/documents/careGroups/$(careGroupId)/members/$(uid);
    }

    function memberExists(careGroupId, uid) {
      return signedIn() && exists(memberDoc(careGroupId, uid));
    }

    function memberData(careGroupId, uid) {
      return get(memberDoc(careGroupId, uid)).data;
    }

    function hasRole(careGroupId, uid, role) {
      return memberExists(careGroupId, uid) && role in memberData(careGroupId, uid).roles;
    }

    function hasAnyRole(careGroupId, uid, roles) {
      return memberExists(careGroupId, uid)
        && memberData(careGroupId, uid).roles.hasAny(roles);
    }

    // True if the user is a member of this care group document OR of its linked
    // "team" document (see setup: one doc holds members, the other holds household
    // fields, cross-linked by careGroupId).
    function isCareGroupMember(careGroupDocId) {
      return signedIn() && (
        memberExists(careGroupDocId, request.auth.uid)
        || (
          exists(/databases/$(database)/documents/careGroups/$(careGroupDocId))
          && get(/databases/$(database)/documents/careGroups/$(careGroupDocId)).data.keys().hasAny(['careGroupId'])
          && memberExists(
            get(/databases/$(database)/documents/careGroups/$(careGroupDocId)).data.careGroupId,
            request.auth.uid
          )
        )
      );
    }

    // The document id where members/{uid} and roles are stored.
    function careTeamId(careGroupDocId) {
      return memberExists(careGroupDocId, request.auth.uid)
        ? careGroupDocId
        : (
            exists(/databases/$(database)/documents/careGroups/$(careGroupDocId))
            && get(/databases/$(database)/documents/careGroups/$(careGroupDocId)).data.keys().hasAny(['careGroupId'])
            ? get(/databases/$(database)/documents/careGroups/$(careGroupDocId)).data.careGroupId
            : careGroupDocId
          );
    }

    function isPrincipalCarerForCareGroup(careGroupId) {
      return hasRole(careTeamId(careGroupId), request.auth.uid, 'principal_carer');
    }

    function isCarerOrPrincipalForCareGroup(careGroupId) {
      let team = careTeamId(careGroupId);
      return hasAnyRole(team, request.auth.uid, ['principal_carer', 'carer']);
    }

    function isFinancialOrPrincipalForCareGroup(careGroupId) {
      let team = careTeamId(careGroupId);
      return hasAnyRole(team, request.auth.uid, ['principal_carer', 'financial_manager']);
    }

    function isExpenseReaderForCareGroup(careGroupId) {
      let team = careTeamId(careGroupId);
      // Conservative default from matrix: plain carers excluded until product confirms.
      return hasAnyRole(team, request.auth.uid, [
        'principal_carer',
        'financial_manager',
        'power_of_attorney',
      ]);
    }

    function isPrincipalOrPoaForCareGroup(careGroupId) {
      let team = careTeamId(careGroupId);
      return hasAnyRole(team, request.auth.uid, ['principal_carer', 'power_of_attorney']);
    }

    function isReceivesCareOnlyMember(careGroupId) {
      let team = careTeamId(careGroupId);
      return memberExists(team, request.auth.uid)
        && hasRole(team, request.auth.uid, 'receives_care')
        && !hasAnyRole(team, request.auth.uid, [
          'principal_carer',
          'carer',
          'financial_manager',
          'power_of_attorney',
        ]);
    }

    function canReadTaskAsRecipientUser(task) {
      // TODO: align recipientId semantics (profile id vs auth uid) on tasks.
      return (task.keys().hasAny(['assignedTo']) && task.assignedTo == request.auth.uid)
        || (task.keys().hasAny(['recipientId']) && task.recipientId == request.auth.uid);
    }

    function noteRequiresPrincipalOrPoa(note) {
      return (note.keys().hasAny(['sensitive']) && note.sensitive == true)
        || (note.keys().hasAny(['category']) && note.category == 'legal');
    }

    function canReadMedicationList(careGroupId) {
      let team = careTeamId(careGroupId);
      return isCarerOrPrincipalForCareGroup(careGroupId)
        || hasRole(team, request.auth.uid, 'power_of_attorney');
    }

    function canAuthorCareGroupNotes(careGroupId) {
      let team = careTeamId(careGroupId);
      return hasAnyRole(team, request.auth.uid, [
        'principal_carer',
        'carer',
        'power_of_attorney',
      ]);
    }

    function diffKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    function diffKeysCreate() {
      return request.resource.data.keys();
    }

    function emailMatchesInvite(invitation) {
      return invitation.keys().hasAny(['invitedEmail'])
        && request.auth.token.keys().hasAny(['email'])
        && invitation.invitedEmail == request.auth.token.email;
    }

    // --- Top-level collections ---------------------------------------------

    match /users/{userId} {
      allow read: if isSelf(userId);

      allow create: if isSelf(userId)
        && diffKeysCreate().hasOnly([
          'displayName',
          'email',
          'photoUrl',
          'avatarIndex',
          'phone',
          'dateOfBirth',
          'simpleMode',
          'createdAt',
        ]);

      allow update: if isSelf(userId)
        && !diffKeys().hasAny(['careGroupIds']);

      allow delete: if false;
    }

    match /users/{userId}/notifications/{notificationId} {
      allow read, update: if isSelf(userId);
      allow create, delete: if false;
    }

    match /invitations/{invitationId} {
      allow read: if signedIn() && (
        emailMatchesInvite(resource.data)
        || (
          resource.data.keys().hasAll(['careGroupId'])
          && isCareGroupMember(resource.data.careGroupId)
        )
      );

      allow create: if signedIn()
        && request.resource.data.keys().hasAll([
          'careGroupId',
          'householdId',
          'invitedEmail',
          'invitedBy',
          'status',
          'createdAt',
        ])
        && hasRole(careTeamId(request.resource.data.careGroupId), request.auth.uid, 'principal_carer')
        && request.resource.data.invitedBy == request.auth.uid
        && request.resource.data.status == 'pending';

      allow update: if signedIn() && (
        (
          emailMatchesInvite(resource.data)
          && resource.data.status == 'pending'
          && request.resource.data.status in ['accepted', 'declined']
        )
        || (
          resource.data.keys().hasAny(['careGroupId'])
          && hasRole(careTeamId(resource.data.careGroupId), request.auth.uid, 'principal_carer')
        )
      );

      allow delete: if signedIn()
        && resource.data.keys().hasAny(['careGroupId'])
        && hasRole(careTeamId(resource.data.careGroupId), request.auth.uid, 'principal_carer');
    }

    match /carePathways/{pathwayId} {
      allow read: if signedIn() && (
        resource.data.system == true
        || (
          resource.data.system == false
          && resource.data.keys().hasAny(['createdBy'])
          && resource.data.createdBy == request.auth.uid
        )
      );

      allow create: if signedIn()
        && request.resource.data.system == false
        && request.resource.data.createdBy == request.auth.uid;

      allow update, delete: if signedIn()
        && resource.data.system == false
        && resource.data.keys().hasAny(['createdBy'])
        && resource.data.createdBy == request.auth.uid;
    }

    match /careGroups/{careGroupId}/members/{userId} {
      allow read: if isCareGroupMember(careGroupId);

      allow create: if signedIn() && (
        (
          isSelf(userId)
          && request.resource.data.keys().hasAll(['roles', 'displayName', 'joinedAt', 'kudosScore'])
        )
        || hasRole(careTeamId(careGroupId), request.auth.uid, 'principal_carer')
      );

      allow update: if signedIn()
        && isCareGroupMember(careGroupId)
        && !diffKeys().hasAny(['kudosScore'])
        && (
          (
            isSelf(userId)
            && diffKeys().hasOnly(['messagingToken', 'simpleMode', 'displayName', 'photoUrl'])
          )
          || (
            hasRole(careTeamId(careGroupId), request.auth.uid, 'principal_carer')
            && !diffKeys().hasAny(['joinedAt'])
          )
        );

      allow delete: if signedIn()
        && hasRole(careTeamId(careGroupId), request.auth.uid, 'principal_carer')
        && !isSelf(userId);
    }

    // Recommended chat location (not in brief schema; adjust if you nest under careGroups).
    match /careGroups/{careGroupId}/messages/{messageId} {
      allow read: if signedIn()
        && isCareGroupMember(careGroupId)
        && !isReceivesCareOnlyMember(careGroupId);

      allow create: if signedIn()
        && isCareGroupMember(careGroupId)
        && !isReceivesCareOnlyMember(careGroupId)
        && request.resource.data.keys().hasAll(['senderId', 'createdAt', 'body'])
        && request.resource.data.senderId == request.auth.uid;

      allow update, delete: if false;
    }

    match /careGroups/{careGroupId} {
      allow read: if isCareGroupMember(careGroupId);

      allow create: if signedIn() && (
        (
          request.resource.data.keys().hasAll(['careGroupId', 'name', 'createdBy', 'createdAt'])
          && request.resource.data.createdBy == request.auth.uid
        )
        || (
          request.resource.data.keys().hasAll(['name', 'careGroupId', 'recipientIds', 'pathwayIds', 'address', 'addressType', 'createdBy', 'createdAt'])
          && request.resource.data.createdBy == request.auth.uid
          && isCareGroupMember(request.resource.data.careGroupId)
        )
      );

      allow update: if signedIn()
        && isPrincipalCarerForCareGroup(careGroupId)
        && request.resource.data.careGroupId == resource.data.careGroupId;

      allow delete: if false;

      match /tasks/{taskId} {
        allow read: if isCareGroupMember(careGroupId)
          && (
            !isReceivesCareOnlyMember(careGroupId)
            || canReadTaskAsRecipientUser(resource.data)
          );

        allow create: if isCareGroupMember(careGroupId)
          && isCarerOrPrincipalForCareGroup(careGroupId)
          && request.resource.data.keys().hasAll(['title', 'status', 'createdBy', 'createdAt'])
          && request.resource.data.createdBy == request.auth.uid;

        allow update: if isCareGroupMember(careGroupId)
          && isCarerOrPrincipalForCareGroup(careGroupId)
          && request.resource.data.createdBy == resource.data.createdBy;

        allow delete: if isPrincipalCarerForCareGroup(careGroupId);
      }

      match /notes/{noteId} {
        allow read: if isCareGroupMember(careGroupId)
          && (
            !noteRequiresPrincipalOrPoa(resource.data)
            || isPrincipalOrPoaForCareGroup(careGroupId)
          )
          && (
            !isReceivesCareOnlyMember(careGroupId)
            || !noteRequiresPrincipalOrPoa(resource.data)
          );

        allow create: if isCareGroupMember(careGroupId)
          && canAuthorCareGroupNotes(careGroupId)
          && request.resource.data.keys().hasAll(['title', 'type', 'createdBy', 'createdAt'])
          && request.resource.data.createdBy == request.auth.uid;

        allow update: if isCareGroupMember(careGroupId)
          && canAuthorCareGroupNotes(careGroupId);

        allow delete: if isPrincipalOrPoaForCareGroup(careGroupId);
      }

      match /journalEntries/{entryId} {
        allow read: if isCareGroupMember(careGroupId)
          && !isReceivesCareOnlyMember(careGroupId);

        allow create: if isCareGroupMember(careGroupId)
          && isCarerOrPrincipalForCareGroup(careGroupId);

        allow update: if isCareGroupMember(careGroupId)
          && isCarerOrPrincipalForCareGroup(careGroupId);

        allow delete: if isPrincipalCarerForCareGroup(careGroupId);
      }

      match /medications/{medicationId} {
        allow read: if isCareGroupMember(careGroupId) && canReadMedicationList(careGroupId);

        allow create: if isPrincipalOrPoaForCareGroup(careGroupId);
        // Carers may log doses / inventory; principal+POA retain full control.
        allow update: if isCareGroupMember(careGroupId) && isCarerOrPrincipalForCareGroup(careGroupId);
        allow delete: if isPrincipalOrPoaForCareGroup(careGroupId);
      }

      match /expenses/{expenseId} {
        allow read: if isCareGroupMember(careGroupId) && isExpenseReaderForCareGroup(careGroupId);

        allow create: if isCareGroupMember(careGroupId)
          && isFinancialOrPrincipalForCareGroup(careGroupId);

        allow update, delete: if isCareGroupMember(careGroupId)
          && isFinancialOrPrincipalForCareGroup(careGroupId);
      }

      match /meetings/{meetingId} {
        allow read: if isCareGroupMember(careGroupId) && !isReceivesCareOnlyMember(careGroupId);

        allow create, update: if isCareGroupMember(careGroupId)
          && isCarerOrPrincipalForCareGroup(careGroupId);

        allow delete: if isPrincipalCarerForCareGroup(careGroupId);
      }

      match /documents/{documentId} {
        allow read: if isCareGroupMember(careGroupId) && (
          !resource.data.keys().hasAny(['category'])
          || resource.data.category in ['medical', 'other']
          || (
            resource.data.category == 'legal'
            && isPrincipalOrPoaForCareGroup(careGroupId)
          )
          || (
            resource.data.category == 'financial'
            && (
              isPrincipalOrPoaForCareGroup(careGroupId)
              || hasRole(careTeamId(careGroupId), request.auth.uid, 'financial_manager')
            )
          )
        );

        allow create: if isCareGroupMember(careGroupId)
          && (
            isPrincipalOrPoaForCareGroup(careGroupId)
            || (
              isCarerOrPrincipalForCareGroup(careGroupId)
              && request.resource.data.keys().hasAny(['category'])
              && request.resource.data.category in ['medical', 'other']
            )
          );

        allow update, delete: if isCareGroupMember(careGroupId)
          && isPrincipalOrPoaForCareGroup(careGroupId);
      }

      match /contacts/{contactId} {
        allow read: if isCareGroupMember(careGroupId);

        allow create, update, delete: if isCareGroupMember(careGroupId)
          && isCarerOrPrincipalForCareGroup(careGroupId);
      }

      match /checkins/{checkinId} {
        allow read: if isCareGroupMember(careGroupId)
          && (
            (
              resource.data.keys().hasAny(['private'])
              && resource.data.private == true
              && resource.data.keys().hasAny(['subjectId'])
              && resource.data.subjectId == request.auth.uid
            )
            || (
              (!resource.data.keys().hasAny(['private']) || resource.data.private == false)
              && !isReceivesCareOnlyMember(careGroupId)
            )
            || (
              (!resource.data.keys().hasAny(['private']) || resource.data.private == false)
              && isReceivesCareOnlyMember(careGroupId)
              && resource.data.keys().hasAny(['type'])
              && resource.data.type == 'recipient'
            )
          );

        allow create: if isCareGroupMember(careGroupId)
          && request.resource.data.keys().hasAll(['type', 'subjectId', 'score', 'createdAt'])
          && request.resource.data.subjectId == request.auth.uid;

        allow update, delete: if false;
      }

      // Append-only audit trail (POA-sensitive actions). Prefer Cloud Function creates.
      match /auditLogs/{logId} {
        allow read: if isCareGroupMember(careGroupId) && isPrincipalOrPoaForCareGroup(careGroupId);
        allow create: if signedIn()
          && request.resource.data.keys().hasAll(['actorId', 'action', 'createdAt'])
          && request.resource.data.actorId == request.auth.uid;
        allow update, delete: if false;
      }

      // Tracking / telemetry — client writes off; principal/POA may read. Prefer Fn ingestion.
      match /tracking/{path=**} {
        allow read: if isCareGroupMember(careGroupId) && isPrincipalOrPoaForCareGroup(careGroupId);
        allow write: if false;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
